FROM python:3.11-alpine

LABEL \
  org.opencontainers.image.source=https://github.com/yellow-corps/ibis \
  org.opencontainers.image.description="ibis discord bot" \
  org.opencontainers.image.licenses=MIT

ENV \
  PYTHONDONTWRITEBYTECODE=1 \
  PYTHONUNBUFFERED=1

RUN \
  addgroup -S discord && \
  adduser -S discord -G discord

ARG DUCKDB_BUILD_DEPENDENCIES="g++ musl-dev linux-headers"
RUN \
  apk add --no-cache $DUCKDB_BUILD_DEPENDENCIES && \
  python -m pip install --upgrade pip

USER discord
WORKDIR /home/discord

COPY ./requirements.txt requirements.txt
RUN \
  export PATH="$PATH:/home/discord/.local/bin" && \
  python -m pip install --user -r requirements.txt && \
  python -m pip cache purge && \
  rm requirements.txt

USER root
RUN apk del $DUCKDB_BUILD_DEPENDENCIES 
USER discord

RUN \
  # disable startup version check DM - it's so annoying!!
  sed -i -e \
  's/await send_to_owners_with_prefix_replaced(bot, outdated_red_message)/pass/' \
  "$(pip show Red-DiscordBot | grep "Location:" | awk '{print $2}')/redbot/core/_events.py" && \
  # rename invite command so we can alias invite to other things
  sed -i -e \
  's/async def invite\b/async def botinviteurl/' \
  "$(pip show Red-DiscordBot | grep "Location:" | awk '{print $2}')/redbot/core/core_commands.py" && \
  # remove deprecated shutdown_timeout assignment
  sed -i -e \
  's/shutdown_timeout=120//' \
  "$(pip show Red-DiscordBot | grep "Location:" | awk '{print $2}')/redbot/core/_rpc.py"

COPY --chown=discord ./config/config.json .config/Red-DiscordBot/config.json
COPY --chown=discord ./local-share/data/ibis .local/share/Red-DiscordBot/data/ibis
COPY --chown=discord ./submodules/Trusty-cogs/extendedmodlog/ .local/share/Red-DiscordBot/cogs/extendedmodlog/
COPY --chown=discord ./submodules/coffee-cogs/msgmover/ .local/share/Red-DiscordBot/cogs/msgmover/
COPY --chown=discord ./cogs/ .local/share/Red-DiscordBot/cogs/
COPY ./ibis/ /usr/local/lib/python3.11/site-packages/ibis/

CMD ["python", ".local/bin/redbot", "ibis", "--rpc", "--team-developers-are-owners", "--mentionable", "--prefix", "[@]"]
