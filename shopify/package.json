{
  "name": "ibis-shopify",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "Yellow Corps",
    "url": "https://github.com/yellow-corps"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "esbuild src/index.ts --outfile=target/index.mjs --platform=node --bundle --minify --packages=external --format=esm",
    "logout": "shopify auth logout",
    "deploy": "tsx --env-file ../.env src/configure.ts && shopify app deploy"
  },
  "dependencies": {
    "@shopify/shopify-api": "^12.3.0",
    "@shopify/shopify-app-express": "^6.0.5",
    "express": "^5.2.1",
    "ws": "^8.18.0"
  },
  "optionalDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.70.0"
  },
  "devDependencies": {
    "@shopify/cli": "^3.90.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.3",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.27.3",
    "tsx": "^4.21.0"
  }
}
